PORT=4000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=consorcio

# JWT
JWT_SECRET=cambiar_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Correo electrónico (SMTP)
# Copie estas variables a su .env y complete con su servidor SMTP.
# Si no las configura, la app funciona igual pero no se envían correos.
# ---------------------------------------------------------------------------
# Ejemplo Gmail: use SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# y una "Contraseña de aplicación" en la cuenta de Google.
#
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_usuario
# SMTP_PASSWORD=tu_contraseña
# MAIL_FROM=consorcio@tudominio.com
# MAIL_FROM_NAME=Consorcio
